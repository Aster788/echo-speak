# Copy to .env.local and fill in values:
#   cp .env.local.example .env.local
#
# Local Supabase URL and keys: run `npx supabase status` (requires `supabase start`).

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase (local defaults from `npx supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# Feishu (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
