# Copy to .env.local and fill in values:
#   cp .env.local.example .env.local
#
# --- Local development (default) ---
# Run `npx supabase start`, then `npx supabase status` for URL and keys.

# LLM (DeepSeek example)
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Supabase local (`npx supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# --- Cloud production (Vercel only; do not mix with local URL in .env.local) ---
# Project: echo-speak — ref ejgybfiywdbnfzckjqao (ap-northeast-1)
# Dashboard: https://supabase.com/dashboard/project/ejgybfiywdbnfzckjqao/settings/api
# NEXT_PUBLIC_SUPABASE_URL=https://ejgybfiywdbnfzckjqao.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key from dashboard>
# SUPABASE_SERVICE_ROLE_KEY=<service_role secret from dashboard — server-only>
#
# Sync to Vercel: SUPABASE_SERVICE_ROLE_KEY=... ./scripts/sync-vercel-env.sh
# See docs/deployment.md

# Feishu (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
