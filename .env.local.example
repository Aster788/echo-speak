# Copy to .env.local and fill in values.
# Local dev: run `npm run sync-dev-supabase-env` for .env.development.local (overrides Supabase on `npm run dev`).

# LLM (DeepSeek example)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Supabase (cloud production — local dev uses .env.development.local)
NEXT_PUBLIC_SUPABASE_URL=https://ejgybfiywdbnfzckjqao.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never shown in Settings UI; used by API routes and scripts only
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Feishu notes sync
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: use LLM transcript cleaner instead of sync clean (default off)
IMPORT_USE_LLM_CLEANER=0

# Optional: public site URL for auth email redirects (defaults to the URL you open in the browser)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
